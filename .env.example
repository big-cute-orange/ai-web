# ====== LLM Provider ======
# DeepSeek：https://platform.deepseek.com/api_keys
NUXT_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
NUXT_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问（阿里云百炼）：https://bailian.console.aliyun.com/?apiKey=1
NUXT_QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
NUXT_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ====== Auth ======
# JWT 签名密钥，生产环境务必换成足够长的随机串：openssl rand -hex 32
NUXT_JWT_SECRET=dev-only-change-me-in-production

# ====== 微信扫码登录 ======
# 微信开放平台 -> 网站应用：https://open.weixin.qq.com/
NUXT_WECHAT_APP_ID=wx_xxxxxxxxxxxxxxxx
NUXT_WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 微信回调地址，留空则按请求 Host 自动拼成 {protocol}://{host}/api/auth/wechat/callback
# 本地用 cloudflared / ngrok 暴露时建议显式填写，例如：
# NUXT_WECHAT_REDIRECT_URI=https://xxx.trycloudflare.com/api/auth/wechat/callback
NUXT_WECHAT_REDIRECT_URI=

# ====== Database (Supabase Postgres) ======
# DATABASE_DIRECT_URL：直连地址（5432），仅给 drizzle-kit 迁移用
DATABASE_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# DATABASE_URL：连接池地址（6543, pgbouncer），运行时用
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
